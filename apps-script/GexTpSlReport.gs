function buildGexTakeProfitStopLimit(selectedDte){
  var maxDte=gexCleanDte_(selectedDte||gexGetSavedDte_());
  PropertiesService.getDocumentProperties().setProperty(GEX_TPSL.dteProp,String(maxDte));
  var ss=SpreadsheetApp.getActiveSpreadsheet();
  gexWriteNotes_(ss,maxDte);
  var holdings=gexReadHoldings_(ss).slice(0,GEX_TPSL.maxTickers);
  if(!holdings.length)throw new Error('No usable holdings tickers found. Pull Holdings first.');
  var sh=ss.getSheetByName(GEX_TPSL.reportSheet)||ss.insertSheet(GEX_TPSL.reportSheet);
  gexPrepareSheet_(sh);
  var rows=[],errors=[];
  holdings.forEach(function(h){try{var r=gexAnalyzeTicker_(h.ticker,h.price,maxDte);rows.push(gexBuildOutputRow_(h,r));Utilities.sleep(250);}catch(e){errors.push(h.ticker+': '+e.message);var er=[h.ticker,h.qty,gexMoney_(h.cost),gexMoney_(h.costPerShare),h.price||0,'n/a','n/a','n/a','n/a','','n/a','',''];er.assetKind=h.assetKind;rows.push(er);}});
  rows=rows.filter(gexRowHasUsableGex_).sort(gexSortByTpPctDesc_);
  var row=1;
  row=gexTitle_(sh,row,'GEX Take Profit & Stop Limit','Built '+gexNow_()+'. DTE used: ≤ '+maxDte+' days / through '+gexDateAfterDays_(maxDte)+'. TP now uses the next actionable upside GEX wall above spot.');
  row=gexSection_(sh,row,'How To Read This');
  row=gexParagraph_(sh,row,'Call Wall = strongest positive call GEX strike overall. Take Profit = strongest positive call-GEX strike ABOVE current spot, because a wall below spot is already passed. Put Wall = strongest negative put GEX strike overall. Stop Limit = strongest downside put/gamma level BELOW current spot. Gamma Flip = simulated zero-gamma. TP %, SL %, and EST. Loss use cost/share only for personal P&L math.');
  row=gexSection_(sh,row,'Portfolio GEX TP / SL Map');
  row=gexTable_(sh,row,['Ticker','Qty','Cost Basis','Cost / Share','Live Spot','Call Wall','Put Wall','Gamma Flip','Take Profit','TP %','Stop Limit','SL %','EST. Loss'],rows);
  if(errors.length){row=gexSection_(sh,row,'Hidden / Data Issues');row=gexParagraph_(sh,row,errors.join('\n'));}
  gexFinalize_(sh,row);
  gexBuildPhoneGmailTab_(ss,rows,maxDte);
  return'GEX TP & SL complete. DTE: ≤ '+maxDte+' days. TP uses next upside GEX wall above spot. Phone-Gmail updated.'+(errors.length?' Hidden/issues: '+errors.length+'.':'');
}
function buildPhoneGmailGexReport(){return buildGexTakeProfitStopLimit();}
