function gexPhoneFinalize_(sh,lastRow){var widths=[58,42,62,58,58,52,58,52,72];for(var c=1;c<=9;c++)sh.setColumnWidth(c,widths[c-1]);try{sh.hideColumns(2);}catch(e){}if(sh.getMaxColumns()>9)sh.hideColumns(10,sh.getMaxColumns()-9);sh.setFrozenRows(0);sh.getRange(1,1,Math.max(lastRow,1),9).setVerticalAlignment('middle');}
