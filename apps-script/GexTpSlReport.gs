function gexReadHoldings_(ss){var sh=ss.getSheetByName(GEX_TPSL.holdingsSheet);if(!sh)throw new Error('Missing Holdings tab.');var values=sh.getDataRange().getDisplayValues();if(values.length<2)return[];var headers=values[0].map(gexNorm_),ix={};headers.forEach(function(h,i){ix[h]=i;});function col(names,fallback){for(var i=0;i<names.length;i++){if(ix[names[i]]!==undefined)return ix[names[i]];}return fallback;}var cTicker=col(['ticker_symbol','ticker','symbol'],6),cQty=col(['quantity','qty','shares'],10),cCost=col(['cost_basis','cost','basis'],11),cPrice=col(['institution_price','price','current_price'],12),cType=col(['security_type','type'],8),cSub=col(['security_subtype','subtype'],9),cName=col(['security_name','name'],7),out=[],seen={};values.slice(1).forEach(function(r){var ticker=String(r[cTicker]||'').trim().toUpperCase();if(!ticker||seen[ticker]||gexExcludeTicker_(ticker))return;var qty=gexNum_(r[cQty]),cost=gexNum_(r[cCost]);seen[ticker]=true;out.push({ticker:ticker,qty:qty,cost:cost,costPerShare:qty?cost/qty:0,price:gexNum_(r[cPrice]),assetKind:gexAssetKind_(r[cType],r[cSub],r[cName])});});return out;}
function gexAssetKind_(type,sub,name){var s=String([type,sub,name].join(' ')).toLowerCase();if(s.indexOf('common stock')>=0||s.indexOf('depositary receipt')>=0||s==='equity')return'stock';if(s.indexOf('stock')>=0&&s.indexOf('etf')<0&&s.indexOf('fund')<0)return'stock';return'etf';}
