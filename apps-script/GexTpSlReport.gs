function gexAnalyzeTicker_(ticker,fallbackSpot,maxDte){var chain=gexFetchCboeChain_(ticker),spot=Number(chain.spot||fallbackSpot||0);if(!spot)throw new Error('missing spot price');var options=chain.options||[];if(!options.length)throw new Error('empty option chain');var rows=[],callGexByStrike={},putGexByStrike={},netDownByStrike={};options.forEach(function(o){var p=gexParseOption_(o,ticker);if(!p||p.dte<0||p.dte>maxDte||p.oi<GEX_TPSL.minOi)return;var gamma=p.gamma||gexBsGamma_(spot,p.strike,p.dte,p.iv||.35);var gx=gamma*p.oi*100*spot*spot*.01;if(p.type==='P')gx=-Math.abs(gx);else gx=Math.abs(gx);var k=String(p.strike);rows.push(p);if(p.type==='C')callGexByStrike[k]=(callGexByStrike[k]||0)+gx;if(p.type==='P')putGexByStrike[k]=(putGexByStrike[k]||0)+gx;if(p.strike<spot)netDownByStrike[k]=(netDownByStrike[k]||0)+gx;});if(!rows.length)throw new Error('no option rows inside '+maxDte+' DTE');return{spot:spot,callWall:gexMaxPositiveGexStrike_(callGexByStrike),putWall:gexMaxNegativeGexStrike_(putGexByStrike),takeProfit:gexBestPositiveCallGexAbove_(callGexByStrike,spot),stopLimit:gexBestDownsideLevelBelow_(putGexByStrike,spot),gammaFlip:gexSimulatedGammaFlip_(rows,spot),source:chain.source};}
