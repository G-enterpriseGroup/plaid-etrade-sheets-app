function sum_(a,k){return a.reduce(function(s,x){return s+(x[k]||0)},0)}function num_(x){if(x==null||x==='')return 0;if(typeof x==='number')return x;var s=String(x),neg=s.indexOf('(')>=0&&s.indexOf(')')>=0;s=s.replace(/[,$%\s()]/g,'');var n=Number(s);return isNaN(n)?0:neg?-n:n}function pctNum_(x){if(typeof x==='number')return Math.abs(x)>1?x/100:x;var s=String(x||''),n=num_(s);return s.indexOf('%')>=0?n/100:n}function money_(n){return'$'+Number(n||0).toLocaleString('en-US',{minimumFractionDigits:2,maximumFractionDigits:2})}function pct_(n){return(Number(n||0)*100).toFixed(2)+'%'}function norm_(x){return String(x||'').trim().toLowerCase().replace(/\s+/g,'_').replace(/[^a-z0-9_]/g,'')}function clip_(s,n){s=String(s||'');return s.length>n?s.slice(0,n-1)+'…':s}function mrNow_(){return Utilities.formatDate(new Date(),Session.getScriptTimeZone(),'yyyy-MM-dd HH:mm:ss')}function today_(){var n=new Date();return new Date(n.getFullYear(),n.getMonth(),n.getDate())}function strip_(d){return new Date(d.getFullYear(),d.getMonth(),d.getDate())}function days_(a,b){return Math.round((strip_(b).getTime()-strip_(a).getTime())/86400000)}function date_(d){return isNaN(d.getTime())?Utilities.formatDate(new Date(),Session.getScriptTimeZone(),'MMM d, yyyy'):Utilities.formatDate(d,Session.getScriptTimeZone(),'MMM d, yyyy')}function wknd_(d){return d.getDay()===0||d.getDay()===6}function biz1_(y,m){var d=new Date(y,m,1);while(wknd_(d))d.setDate(d.getDate()+1);return strip_(d)}function bizn_(y,m,n){var d=new Date(y,m,1),c=0;while(d.getMonth()===m){if(!wknd_(d))c++;if(c===n)return strip_(d);d.setDate(d.getDate()+1)}return lastBiz_(y,m)}function nthDay_(y,m,w,n){var d=new Date(y,m,1),c=0;while(d.getMonth()===m){if(d.getDay()===w)c++;if(c===n)return strip_(d);d.setDate(d.getDate()+1)}return lastBiz_(y,m)}function lastBiz_(y,m){var d=new Date(y,m+1,0);while(wknd_(d))d.setDate(d.getDate()-1);return strip_(d)}
