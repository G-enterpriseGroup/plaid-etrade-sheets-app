function mrPortfolio_(h){return h.map(function(a){var m=MR_MAP[a.ticker]||['Equity / Unmapped','SPY','Single-stock exposure; validate thesis manually.'],act=action_(a),trimPnl=act.trimQty?act.trimQty*(a.qty?a.pnl/a.qty:0):0;return{ticker:a.ticker,qty:a.qty,value:a.value,pnl:a.pnl,pnlPct:a.pnlPct,sleeve:m[0],thesis:m[2],action:act.label,actValue:act.qty*a.price,trimValue:act.trimQty*a.price,trimPnl:trimPnl,addValue:act.addQty*a.price,tolerance:tol_(a),reason:act.reason,priority:act.label.indexOf('Add-QTY')===0?1:act.label.indexOf('Trim-QTY')===0?2:9}}).sort(function(a,b){return a.priority-b.priority||b.value-a.value})}function action_(a){if(a.pnlPct>.5){var q=Math.max(1,Math.floor(a.qty*.1));return{label:'Trim-QTY '+q,qty:q,trimQty:q,addQty:0,reason:'Profit outlier; estimate trim P&L shown.'}}if(a.pnlPct<-.1){var q2=Math.max(1,Math.floor(a.qty*.15));return{label:'Trim-QTY '+q2,qty:q2,trimQty:q2,addQty:0,reason:'Weak P&L/tolerance pressure; trim language only.'}}if(a.value<2000){var q3=a.price>=100?1:Math.max(1,Math.floor(500/Math.max(a.price,1)));return{label:'Add-QTY '+q3,qty:q3,trimQty:0,addQty:q3,reason:'Small position; add only if macro/sector confirms.'}}return{label:'Hold',qty:0,trimQty:0,addQty:0,reason:'Hold-no-add until macro/news confirms.'}}function tol_(a){return a.pnlPct>.5?'Profit outlier':a.pnlPct<-.1?'Weak':a.value<2000?'Too small':'In tolerance'}
