function mrHoldings_(ss){var sh=ss.getSheetByName(MR_HOLDINGS);if(!sh)throw new Error('Missing Holdings tab.');var v=sh.getDataRange().getDisplayValues(),h=v[0].map(norm_),ix={};h.forEach(function(x,i){ix[x]=i});var fb={ticker_symbol:6,security_name:7,security_type:8,quantity:10,cost_basis:11,institution_price:12,institution_value:13,calculated_market_value:14,unrealized_gain_loss:15,unrealized_gain_loss_pct:16,portfolio_weight:17};function g(r,k){var i=ix[k]!==undefined?ix[k]:fb[k];return i===undefined?'':r[i]}var out=[];v.slice(1).forEach(function(r){var t=String(g(r,'ticker_symbol')||'').trim().toUpperCase(),n=String(g(r,'security_name')||''),ty=String(g(r,'security_type')||'').toLowerCase();if(!t||exclude_(t,n,ty))return;var q=num_(g(r,'quantity')),val=num_(g(r,'institution_value'))||num_(g(r,'calculated_market_value')),p=num_(g(r,'institution_price'));if(!p&&q&&val)p=val/q;out.push({ticker:t,qty:q,price:p,value:val,pnl:num_(g(r,'unrealized_gain_loss')),pnlPct:pctNum_(g(r,'unrealized_gain_loss_pct'))})});return out}function exclude_(t,n,ty){n=String(n||'').toLowerCase();return ty==='cash'||t.indexOf('CUR:')===0||['VMFXX','SWVXX','SPAXX','FDRXX'].indexOf(t)>=0||n.indexOf('money market')>=0||n.indexOf('sweep')>=0}
